# ============================================================================
# ÉLANSTUDIO — environment variables
# Copy this file to .env.local and fill in real values. The app runs WITHOUT
# these (falling back to seed data); fill them in to enable auth, real data,
# and payments.
# ============================================================================

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by the Mercado Pago webhook + admin writes. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=

# --- Mercado Pago (Your integrations → Credentials) ---
# Use TEST credentials while developing.
MP_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=

# --- App ---
# Public base URL — used for checkout return URLs and the MP webhook.
# Local: http://localhost:3000  ·  Production: https://your-app.onrender.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
